Monoalphabetic Cipher Program
import random
import string

msg = input("Enter message to encrypt: ")

def gen_key():
    symbols = list(string.ascii_lowercase)
    sym_shuff = list(string.ascii_lowercase)
    random.shuffle(sym_shuff)
    return dict(zip(symbols, sym_shuff))

key = gen_key()
print("Generated key:", key)

def encryption(msg, keyword):
    cipher = ""
    for char in msg:
        if char.lower() in keyword:   # check lowercase version
            # preserve case
            enc = keyword[char.lower()]
            cipher += enc.upper() if char.isupper() else enc
        else:
            cipher += char
    return cipher

def decryption(ciphertext, keyword):
    plain = ""
    for char in ciphertext:
        if char.lower() in keyword.values():   # check lowercase value
            for k, v in keyword.items():
                if v == char.lower():   # match ignoring case
                    dec = k
                    plain += dec.upper() if char.isupper() else dec
                    break
        else:
            plain += char
    return plain

encrypted = encryption(msg, key)
print("Encrypted text:", encrypted)

decrypted = decryption(encrypted, key)
print("Decrypted text:", decrypted)


Vernam Cipher program
import string

def vernamencrypt(msg, key):
    ct = ""
    pool = list(string.ascii_lowercase)

    for i in range(len(msg)):
        pt = pool.index(msg[i])
        k = pool.index(key[i])
        xor = pt + k

        if xor >= 26:
            xor = xor - 26

        ct += pool[xor]

    return ct

