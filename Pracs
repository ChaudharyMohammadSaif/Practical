msg=input("Enter message to encrypt here: ").replace(" ","")
rails=int(input("Enter no of rails for encryption: "))
def railfence_encrypt(msg,rails):
    mat=[[' ' for i in range(len(msg))] for j in range(rails)]
    row,check=0,0
    for char_indx in range(len(msg)):
        if check==0:
            mat[row][char_indx]=msg[char_indx]
            row += 1
            if row == rails:
                check=1
                row -= 1

        else:
            row -= 1
            mat[row][char_indx]=msg[char_indx]
            if row == 0:
                check=0
                row=1

    ct = ""
    for i in range(rails):
        for j in range(len(msg)):
            if mat[i][j] != ' ':
                ct += mat[i][j]

    return ct

cipher_text = railfence_encrypt(msg, rails)
print("Encrypted message: ", cipher_text)


Columnar Cipher Program
import math
msg = input("Enter the message to encrypt here: ").replace(" ", "")
keyword = input("Enter the word to be used as key: ")

def gentab(msg, col):
    row = math.ceil(len(msg) / col)
    cell = (row * col) - len(msg)
    msg += 'x' * cell

    tab = []
    for i in range(0, len(msg), col):
        tab.append(msg[i:i+col])
    return tab

def columnar(pt, key):
    ct = ""
    key_index = list(enumerate(key))
    key_index.sort(key=lambda x: x[1])
    matrix = gentab(pt, len(key))
    for index, ch in key_index:
        for row in matrix:
            ct += row[index]
    return ct
print(columnar(msg, keyword))


RSA Algorithm Program
import random, math
msg = input("Enter the message to encrypt: ").replace(" ","")

def genprimes(n1,n2):
    primes=[]
    for i in range(n1,n2+1):
        if i>1:
            for j in range(2,i):
                if i%j ==0:
                    break
            else:
                primes.append(i)
    return primes

def genPURPkeys():
    p = random.choice(genprimes(10,20))
    q = random.choice(genprimes(30,40))
    n=p*q
    phi = (p-1)*(q-1)

    e=2
    while (e<phi):
        if math.gcd(e,phi) == 1:
            break
        e+=1

    i=1
    while True:
        d=((phi*i)+1)/e

        if int(d) == d:
            break

        i+=1

    return [e,d,n]

def rsaencrypt(e,n,msg):
    codes = [ord(sym) for sym in msg]
    ct = [(pt**e) % n for pt in codes]
    return ct

def rsadecrypt(d,n,cipher):
    pt = [(ct**int(d))% n for ct in cipher]
    msg=[chr(c) for c in pt]
    return msg

