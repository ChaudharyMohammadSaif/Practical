            <h2>Armstrong Number Checker (Cloud Simulation)</h2>
            <form action="/process" method="get">
                Enter your name:
                <input type="text" name="name"><br><br>

                Enter a number:
                <input type="number" name="num"><br><br>

                <input type="submit" value="Check">
            </form>
