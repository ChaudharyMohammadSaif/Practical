        # Armstrong logic
        temp = num
        power = len(str(num))
        total = 0

        while temp > 0:
            digit = temp % 10
            total += digit ** power
            temp //= 10

        if total == num:
            result_value = "Armstrong Number"
        else:
            result_value = "Not an Armstrong Number"

        result = f"""
        <html>
        <body>
            <h3>Hello {name}</h3>
